# ─── FIREBASE CONFIGURATION (Web SDK) ─────────────────────────────
# Get these from the Firebase Project Settings -> Web App
VITE_FB_API_KEY=your_api_key
VITE_FB_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FB_PROJECT_ID=your_project_id
VITE_FB_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=your_sender_id
VITE_FB_APP_ID=your_app_id
VITE_FB_MEASUREMENT_ID=your_measurement_id

# ─── CENTRAL PLATFORM INTEGRATION ──────────────────────────────────
# The URL of the Central Dashboard
VITE_CENTRAL_URL=http://localhost:5173

# The API URL of the Central Backend (for Auth/SSO Bridge)
VITE_CENTRAL_API_URL=http://localhost:5000

# The local URL of this HR platform
VITE_HR_SELF_URL=http://localhost:4028

# ─── FEATURE FLAGS ──────────────────────────────────────────────────
# Set to true to enable Stripe-related UI components
VITE_USE_STRIPE=false
VITE_MOCK_AUTH=false
VITE_DEBUG_MODE=true
