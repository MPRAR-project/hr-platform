rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // --- USERS ---
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if isUser(userId);
      // Managers can read all users in the system
      allow read: if isAuthenticated(); 
    }

    // --- COMPANIES ---
    match /companies/{companyId} {
      // Anyone authenticated can read company info
      allow read: if isAuthenticated();
      // Owners/Admins can update company info
      allow write: if isAuthenticated(); 
    }

    // --- ALLOWANCES ---
    match /allowances/{allowanceId} {
      // Users can read their own allowances
      allow read: if isAuthenticated() && (resource.data.employeeId == request.auth.uid || request.auth.uid != null);
      // Authenticated users can create/update allowances (scoped by service logic)
      allow read, write: if isAuthenticated();
    }

    // --- ABSENCES ---
    match /absences/{absenceId} {
      allow read, write: if isAuthenticated();
    }

    // --- SITES & CLIENTS ---
    match /sites/{siteId} {
      allow read, write: if isAuthenticated();
    }
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    // --- INVITES ---
    match /invites/{inviteId} {
      allow read: if true; 
      allow write: if isAuthenticated();
    }

    // --- CHAT & NOTIFICATIONS ---
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
    }
    match /notifications/{notifId} {
      allow read, write: if isAuthenticated();
    }

    // General fallback for development
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
