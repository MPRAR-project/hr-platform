rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Secure rules for users, companies, sites, and timesheets
    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Should be further restricted to owners
    }

    match /sites/{siteId} {
      allow read, write: if isAuthenticated();
    }

    match /timesheets/{timesheetId} {
      allow read, write: if isAuthenticated(); // Should be scoped to company/user
    }

    match /invites/{inviteId} {
      allow read: if true; // Public for validation
      allow write: if isAuthenticated();
    }

    // General fallback for development (restrict to authenticated)
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 11, 12) && isAuthenticated();
    }
  }
}
